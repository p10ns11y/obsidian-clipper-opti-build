{
	"name": "obsidian-clipper",
	"version": "1.3.0",
	"description": "Official web clipper for Obsidian.",
	"bin": {
		"obsidian-clipper": "./dist/cli.cjs"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": "./dist/cli.cjs",
		"./api": "./dist/api.mjs"
	},
	"scripts": {
		"defuddle-dev": "node scripts/set-defuddle-dev.js",
		"defuddle-prod": "node scripts/set-defuddle-prod.js",
		"dev:chrome": "node build-extension.mjs chrome development --watch",
		"dev:firefox": "node build-extension.mjs firefox development --watch",
		"dev:safari": "node build-extension.mjs safari development --watch",
		"build:chrome": "node build-extension.mjs chrome production",
		"build:firefox": "node build-extension.mjs firefox production",
		"build:safari": "node build-extension.mjs safari production",
		"build": "npm run build:chrome && npm run build:firefox && npm run build:safari",
		"build:cli": "node scripts/build-cli.mjs",
		"build:api": "node scripts/build-api.mjs",
		"dev": "npm run dev:chrome",
		"test": "vitest run",
		"test:watch": "vitest",
		"update-locales": "ts-node --project scripts/tsconfig.json scripts/update-locales.ts",
		"check-strings": "ts-node --project scripts/tsconfig.json scripts/check-unused-strings.ts",
		"add-locale": "ts-node --project scripts/tsconfig.json scripts/add-locale.ts",
		"prepublishOnly": "npm run build:cli && npm run build:api"
	},
    "devDependencies": {
		"@types/chrome": "^0.0.270",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.4.0",
		"@types/webextension-polyfill": "^0.12.1",
		"@types/webpack-env": "^1.18.5",
		"adm-zip": "^0.5.16",
		"dotenv": "^16.4.1",
		"esbuild": "^0.25.0",
		"sass": "^1.77.8",
		"ts-node": "^10.9.2",
		"typescript": "^5.5.4",
		"vitest": "^4.0.18",
		"webextension-polyfill": "^0.12.0"
	},
	"dependencies": {
		"@types/safari-extension": "^0.0.33",
		"dayjs": "^1.11.13",
		"defuddle": "^0.15.0",
		"dompurify": "^3.0.9",
		"highlight.js": "^11.11.1",
		"linkedom": "^0.18.0",
		"lucide": "^0.359.0",
		"lz-string": "^1.5.0"
	}
}
